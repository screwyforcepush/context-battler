# Phase 02 — Personal Replay Overseer.
#
# The renderer connects to YOUR Convex dev deployment (not a shared one).
# Get this URL by running `npx convex dev` in the repo root and copying the
# `Convex deployment URL` it prints — typically `https://<slug>.convex.cloud`.
#
# Required at runtime; the renderer throws a friendly error if missing.
VITE_CONVEX_URL=https://example-1234.convex.cloud
