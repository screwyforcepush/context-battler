; Godot 4 throwaway web scaffold for the replay-render substrate bet.

config_version=5

[application]

config/name="Context Battler Telefrag Register"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon=""
boot_splash/bg_color=Color(0.005, 0.007, 0.011, 1)
boot_splash/image=""
boot_splash/show_image=false
boot_splash/fullsize=false
boot_splash/use_filter=false

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.005, 0.007, 0.011, 1)
textures/vram_compression/import_etc2_astc=true
