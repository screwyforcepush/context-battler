[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://src/MatchPicker.gd" id="1_picker"]

[node name="MatchPicker" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_picker")

[node name="Root" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 28
theme_override_constants/margin_top = 24
theme_override_constants/margin_right = 28
theme_override_constants/margin_bottom = 24

[node name="Panel" type="PanelContainer" parent="Root"]
layout_mode = 2

[node name="VBox" type="VBoxContainer" parent="Root/Panel"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Header" type="HBoxContainer" parent="Root/Panel/VBox"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="Root/Panel/VBox/Header"]
layout_mode = 2
size_flags_horizontal = 3
text = "Completed Matches"
